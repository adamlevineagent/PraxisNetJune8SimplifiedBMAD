generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  handle                 String                  @unique
  passwordHash           String
  disclosureLevel        DisclosureLevel         @default(STEALTH)
  status                 UserStatus              @default(PENDING)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  approvedAt             DateTime?
  username               String?                 @unique
  onboardingStage        OnboardingStage         @default(HANDLE_SELECTION)
  profile                AgentProfile?
  onboardingConversation OnboardingConversation?
  sentMatches            OpportunityMatch[]      @relation("SentMatches")
  receivedMatches        OpportunityMatch[]      @relation("ReceivedMatches")
  privacySettings        PrivacySettings?
  professionalEssence    ProfessionalEssence?

  @@index([email])
  @@index([handle])
  @@index([status])
}

model AgentProfile {
  id                 String                    @id @default(uuid())
  userId             String                    @unique
  positionMatrix     Json
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  communicationStyle String?
  name               String?
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  participantIn      ConversationParticipant[]

  @@index([userId])
}

model ConversationLog {
  id           String                    @id @default(uuid())
  ranAt        DateTime                  @default(now())
  transcript   String
  outcomes     Json?
  createdAt    DateTime                  @default(now())
  participants ConversationParticipant[]
  matches      OpportunityMatch[]

  @@index([ranAt])
}

model ConversationParticipant {
  id             String          @id @default(uuid())
  conversationId String
  profileId      String
  conversation   ConversationLog @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  profile        AgentProfile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([conversationId, profileId])
  @@index([conversationId])
  @@index([profileId])
}

model OpportunityMatch {
  id             String            @id @default(uuid())
  conversationId String
  userId         String
  targetUserId   String
  status         OpportunityStatus @default(PENDING)
  summary        String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  conversation   ConversationLog   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  targetUser     User              @relation("SentMatches", fields: [targetUserId], references: [id], onDelete: Cascade)
  user           User              @relation("ReceivedMatches", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId, conversationId])
  @@index([conversationId])
  @@index([userId])
  @@index([targetUserId])
  @@index([status])
}

model EmailVerification {
  id        String   @id @default(uuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ProfessionalEssence {
  id                 String   @id @default(uuid())
  userId             String   @unique
  narrative          String
  currentFocus       Json
  seekingConnections Json
  offeringExpertise  Json
  metadata           Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PrivacySettings {
  id                String       @id @default(uuid())
  userId            String       @unique
  narrativeLevel    PrivacyLevel @default(MEMBER)
  currentFocusLevel PrivacyLevel @default(MEMBER)
  seekingLevel      PrivacyLevel @default(MEMBER)
  offeringLevel     PrivacyLevel @default(MEMBER)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdminActivity {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  targetId  String
  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
  @@index([action])
  @@index([createdAt])
}

model OnboardingConversation {
  id                 String    @id @default(uuid())
  userId             String    @unique
  conversationId     String    @unique
  agentName          String
  communicationStyle String
  transcript         Json
  turnCount          Int       @default(0)
  status             String    @default("IN_PROGRESS")
  completedAt        DateTime?
  startedAt          DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([status])
}

enum DisclosureLevel {
  OPEN
  STEALTH
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  INACTIVE
  PENDING_APPROVAL
  NEEDS_INFO
}

enum OpportunityStatus {
  PENDING
  INTERESTED
  NOT_INTERESTED
  MUTUAL
  INTRODUCED
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum OnboardingStage {
  HANDLE_SELECTION
  PRIVACY_SETUP
  AGENT_NAMING
  PROFESSIONAL_ESSENCE
  AWAITING_APPROVAL
  COMPLETED
}

enum PrivacyLevel {
  PUBLIC
  MEMBER
  TRUSTED
}
